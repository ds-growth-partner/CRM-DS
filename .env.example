# Supabase — fuente de verdad única
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Credenciales de integración (se guardan por tenant en tenant_credentials)
# Para desarrollo single-tenant, se pueden poner aquí:
N8N_BASE_URL=https://your-n8n.example.com
N8N_WEBHOOK_SECRET=your-hmac-secret
META_WABA_ID=your-waba-id
META_PHONE_NUMBER_ID=your-phone-number-id
META_ACCESS_TOKEN=your-meta-access-token
GOOGLE_CALENDAR_ID=primary
